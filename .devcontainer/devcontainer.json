{
  "name": "CS3704 Canvas Project",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "pip install -e '.[ai,gemini,autodownload]' && pip install -e 'src/sdk/'",
  "remoteEnv": {
    "CANVAS_BASE_URL": "https://canvas.vt.edu"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "ms-python.mypy-type-checker"
      ]
    }
  },
  "postStartCommand": "echo 'Set CANVAS_TOKEN in your shell or .env before running the SDK. CANVAS_BASE_URL defaults to canvas.vt.edu.'"
}
