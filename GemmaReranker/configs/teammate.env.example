# =============================================================================
# Teammate Environment Template
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# Your HuggingFace token (required for gated Gemma models)
# Get at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Your Canvas API token (for dataset generation only)
# Get at: https://canvas.vt.edu → Account → Settings → New Access Token
CANVAS_TOKEN=vt_your_token_here

# Your handle/username (used for anonymization and file naming)
YOUR_HANDLE=your_handle_here

# Spark GPU slot assignment (optional, for remote Spark runs)
# Set to 0 for slot0, 1 for slot1, etc.
# SPARK_GPU_SLOT=0
