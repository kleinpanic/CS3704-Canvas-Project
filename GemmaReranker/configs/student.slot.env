# =============================================================================
# Student Slot ENV — Gemma-4-2B-IT
# QLoRA-friendly: fp8 quantization keeps it under 8GB
# =============================================================================

MODEL=google/Gemma-4-2B-IT
PORT=8001
MAX_MODEL_LEN=131072
MAX_NUM_SEQS=256
GPU_MEMORY_UTIL=0.60

# fp8 quantization — ~4GB vRAM, leaves headroom for training on same GPU
EXTRA_ARGS=--trust-remote-code --tensor-parallel-size 1 --quantization fp8
