# =============================================================================
# Teacher Slot ENV — Gemma-4-31B-IT-NVFP4 on Blackwell
# Source values from spark-ai-v2/LLM/vLLM/GemmaSuper/slot0.env
# =============================================================================

MODEL=nvidia/Gemma-4-31B-IT-NVFP4
PORT=8000
MAX_MODEL_LEN=262144
MAX_NUM_SEQS=64
GPU_MEMORY_UTIL=0.40
KV_CACHE_DTYPE=fp8

# vLLM args for Gemma 4 NVFP4 on Blackwell
# --quantization modelopt: required for nvidia NVFP4 checkpoint format
EXTRA_ARGS=--quantization modelopt --enable-chunked-prefill --enable-prefix-caching --trust-remote-code --tensor-parallel-size 1
