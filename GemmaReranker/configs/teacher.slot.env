# =============================================================================
# Teacher Slot ENV — Gemma-4-31B-IT-NVFP4 (GemmaSuper / nvidia/Gemma-4-31B-IT-NVFP4)
# Source: /srv/spark-ai-v2/LLM/vLLM/GemmaSuper/slot0.env
# =============================================================================

MODEL=nvidia/Gemma-4-31B-IT-NVFP4
PORT=8000
MAX_MODEL_LEN=262144
MAX_NUM_SEQS=64
GPU_MEMORY_UTIL=0.85
KV_CACHE_DTYPE=fp8

# vLLM args for Gemma 4 NVFP4 on Blackwell GB10
# --quantization modelopt: required for nvidia NVFP4 checkpoint format
EXTRA_ARGS=--quantization modelopt --enable-chunked-prefill --enable-prefix-caching --trust-remote-code --enable-auto-tool-choice --tool-call-parser gemma4 --reasoning-parser gemma4 --tensor-parallel-size 1 --pipeline-parallel-size 1
